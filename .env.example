# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"
SILICONFLOW_API_KEY="MY_SILICONFLOW_API_KEY"
AI_DAILY_LIMIT="10"
ADMIN_TOKEN="change-me-before-deploy"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional. Used when GitHub Pages frontend calls a Vercel/server API.
# Example: VITE_API_BASE_URL="https://your-vercel-project.vercel.app"
VITE_API_BASE_URL=""

# Optional comma-separated browser origins allowed to call the API.
# Example: CORS_ORIGINS="https://echoingstill-lab.github.io,http://localhost:3000"
CORS_ORIGINS="https://echoingstill-lab.github.io"

# Optional cloud sync. Configure these only on Vercel/server, never in frontend Pages.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SYNC_AUTH_SECRET=""
